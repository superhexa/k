# OpenRouter API (for Minimax model via OpenRouter)
# Get your free key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local dev fallback only: set this if you want direct browser calls outside Vercel
VITE_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI API (optional backup)
# Get your free key from https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Copy to .env (gitignored) and deploy to Vercel with these environment variables
# In Vercel: Settings → Environment Variables
