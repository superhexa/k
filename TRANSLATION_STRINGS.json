        "title": "Lorentz Factor",
        "branch": "Modern",
        "difficulty": "Medium",
        "question": "What is the Lorentz factor γ for v = 0.8c?",
        "hint": "γ = 1/√(1-β²)",
        "answer": "1.667",
        "unit": ""
      },
